{
  "name": "nova-inns-apartments-front",
  "version": "1.2.3",
  "author": "Nova Alex Labs",
  "scripts": {
    "ng": "ng",
    "tw": "npx @tailwindcss/cli -i src/tailwind.input.css -o src/styles.css",
    "tw:watch": "npm run tw -- --watch",
    "start": "concurrently \"npm:tw:watch\" \"ng serve\"",
    "build": "npm run gen-version && npm run tw && ng build",
    "gen-version": "node scripts/gen-version.mjs",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "echarts": "^6.0.0",
    "leaflet": "^1.9.4",
    "lucide-angular": "^1.0.0",
    "ngx-echarts": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/cli": "^4.2.4",
    "@types/leaflet": "^1.9.21",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.2"
  }
}
